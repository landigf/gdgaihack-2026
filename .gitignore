<!-- claudeflow-teamkit-gitignore:start -->
# ClaudeFlow Team Kit
.claudeflow/checkpoints/
.claudeflow/memory/
traces/
pipelines/.claudeflow/
pipelines/traces/
.env
.env.local
.DS_Store
<!-- claudeflow-teamkit-gitignore:end -->

# Node / npm
node_modules/
npm-debug.log*

# Benchmarks
benchmarks/results/*.json
benchmarks/results/*.png
# Heavy / fetched / generated dataset bytes are ignored; manifests + synthetic SOPs commit.
benchmarks/datasets/*/sources/
benchmarks/datasets/*/app.db
benchmarks/datasets/*/app.db-*
benchmarks/datasets/*/cache/
benchmarks/datasets/*/.lock
# Default-ignore any new top-level dataset dir without manifest scaffolding by adding
# entries here; per-dataset manifests + READMEs + synthetic SOPs are tracked by default.

# Evidence artifacts (can be large / sensitive)
doc/specs/cut-the-cord/evidence/*.pcap
doc/specs/cut-the-cord/evidence/*.mp4
doc/specs/cut-the-cord/evidence/*.mov

# Per-developer Claude Code overrides (committed settings.json is the team default)
.claude/settings.local.json

# Saved-page assets bundled by the browser when archiving HTML (root-level only).
# We keep the .html itself in doc/specs/cut-the-cord/evidence/ but the asset folder
# at repo root from a "Save Page As..." is noise.
/Cut the Cord *_files/
/*_files/

# Python venv + cache
.venv/
__pycache__/
*.pyc

# Benchmark run artifacts (results/ summary kept; raw traces ignored)
benchmarks/results/raw/
benchmarks/results/*.jsonl.tmp
