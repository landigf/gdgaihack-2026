# ClaudeFlow Team Kit
# Copy this file to .env.local and fill only the variables you actually have.
# Never commit real keys.
#
# ClaudeFlow is API-only. It never consumes a Claude Max / Claude Code subscription.
# Every runtime here is paid for per-token by an API key, or runs locally on Ollama.
# If you leave CLAUDEFLOW_RUNTIME unset, ClaudeFlow auto-picks a provider based on
# which API key is present (OPENAI_API_KEY > GEMINI_API_KEY > ANTHROPIC_API_KEY > ...).

CLAUDEFLOW_RUNTIME=gemini
CLAUDEFLOW_MODEL=gemini-2.5-flash-lite

# Main hosted path for hackathon work and the default structured-request path
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional research / serious-second-opinion path
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Anthropic API path for final review and final verification.
# This is pay-per-token and does NOT use a Claude Max / Claude Code subscription.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional low-cost alternative (OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Local worker path for bulk drafting, reviews, summaries, rewrites, and low-cost helper runs
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=auto
