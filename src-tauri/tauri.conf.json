{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rover",
  "version": "0.1.0",
  "identifier": "app.rover.demo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rover",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 620,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "resources": {
      "../backend/": "backend/"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
