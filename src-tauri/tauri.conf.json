{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Houston",
  "version": "0.1.0",
  "identifier": "app.houston.demo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Houston",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 620,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 18 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "resources": {
      "../backend/main.py": "backend/main.py",
      "../backend/config.py": "backend/config.py",
      "../backend/models.py": "backend/models.py",
      "../backend/parsing.py": "backend/parsing.py",
      "../backend/chunking.py": "backend/chunking.py",
      "../backend/ollama_client.py": "backend/ollama_client.py",
      "../backend/store.py": "backend/store.py",
      "../backend/indexer.py": "backend/indexer.py",
      "../backend/retriever.py": "backend/retriever.py",
      "../backend/requirements.txt": "backend/requirements.txt"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
