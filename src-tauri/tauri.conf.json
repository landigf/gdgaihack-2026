{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Houston",
  "version": "0.1.0",
  "identifier": "app.houston.demo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Houston",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 620,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 18 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend/main.py": "backend/main.py",
      "../backend/config.py": "backend/config.py",
      "../backend/models.py": "backend/models.py",
      "../backend/parsing.py": "backend/parsing.py",
      "../backend/chunking.py": "backend/chunking.py",
      "../backend/ollama_client.py": "backend/ollama_client.py",
      "../backend/mlx_client.py": "backend/mlx_client.py",
      "../backend/prompts.py": "backend/prompts.py",
      "../backend/store.py": "backend/store.py",
      "../backend/indexer.py": "backend/indexer.py",
      "../backend/retriever.py": "backend/retriever.py",
      "../backend/requirements.txt": "backend/requirements.txt",
      "../backend/ares/__init__.py": "backend/ares/__init__.py",
      "../backend/ares/perf.py": "backend/ares/perf.py",
      "../backend/ares/prompts.py": "backend/ares/prompts.py",
      "../backend/ares/router.py": "backend/ares/router.py",
      "../backend/ares/voice.py": "backend/ares/voice.py",
      "../backend/cache/__init__.py": "backend/cache/__init__.py",
      "../backend/cache/sensor_producer.py": "backend/cache/sensor_producer.py",
      "../backend/cache/tile_cache.py": "backend/cache/tile_cache.py",
      "../backend/agent_tools/__init__.py": "backend/agent_tools/__init__.py",
      "../backend/agent_tools/houston_sdk.py": "backend/agent_tools/houston_sdk.py",
      "../backend/agent_tools/python_exec.py": "backend/agent_tools/python_exec.py",
      "../mars-corpus/**/*.pdf": "mars-corpus/",
      "../mars-corpus/manifest.json": "mars-corpus/manifest.json"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  }
}
