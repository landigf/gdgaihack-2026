{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Hackathon mode for team PoliSa @ GDG AI HACK 2026 (track: Cut the Cord). Any agent (Claude Code / Codex / Copilot) cloning this repo runs full-auto: bypass approvals, no command-confirmation prompts. Destructive ops still denied below. Personal overrides go in .claude/settings.local.json (gitignored).",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Skill",
      "Agent",
      "NotebookEdit",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npx *)",
      "Bash(npx claudeflow *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(uv *)",
      "Bash(ollama *)",
      "Bash(./scripts/*)",
      "Bash(scripts/*)",
      "Bash(bash scripts/*)",
      "Bash(make *)",
      "Bash(cargo *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(rm -f .git/index.lock)",
      "Bash(rm -f traces/*)",
      "Bash(rm -rf traces/*)",
      "Bash(rm -rf pipelines/traces/*)",
      "Bash(rm -rf .claudeflow/checkpoints/*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(*git push * --force *)",
      "Bash(*git push * -f *)",
      "Bash(*git push --force *)",
      "Bash(*git reset --hard origin/main*)",
      "Bash(*git reset --hard origin/master*)",
      "Bash(gh repo delete*)",
      "Bash(gh release delete*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true
}
